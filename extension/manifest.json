{
  "manifest_version": 3,
  "name": "Call Transcripter",
  "version": "0.1.0",
  "description": "Record and transcribe browser calls (Meet, Zoom, Teams) using OpenAI Whisper, linked to Supabase clients.",
  "permissions": [
    "tabCapture",
    "storage",
    "tabs",
    "scripting",
    "offscreen",
    "notifications",
    "activeTab"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://*.zoom.us/*",
    "https://teams.microsoft.com/*",
    "https://api.openai.com/*",
    "https://*.supabase.co/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Call Transcripter"
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://*.zoom.us/wc/*",
        "https://*.zoom.us/j/*",
        "https://teams.microsoft.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/offscreen/offscreen.html", "src/history/history.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
